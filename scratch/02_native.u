Restate.Vm.sysEnd : Restate.Vm ->{IO, Exception} ()
Restate.Vm.sysEnd vm =
  dll = FFI.DLL.openByName Restate.Vm.libName
  f   = FFI.DLL.getSymbol dll "restate_vm_sys_end"
          (FFI.Spec.fnIO1 FFI.Type.uint64 FFI.Type.int32)
  Restate.Native.checkVoid "sys_end" (f (Restate.Vm.vmHandle vm))

-- Drain all output bytes from the VM (call after progress loop)
Restate.Vm.takeAllOutput : Restate.Vm ->{IO, Exception} Bytes
Restate.Vm.takeAllOutput vm =
  go acc =
    chunk = Restate.Vm.takeOutput vm 4096
    match chunk with
      None -> acc
      Some bs -> go (acc ++ bs)
  go Bytes.empty
