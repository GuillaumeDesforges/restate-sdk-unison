    Restate.Native.checkVoid "propose_run_completion" (f (Restate.Vm.vmHandle vm) nh vpin vlen isSuccess)
  )

Restate.Vm.sysWriteOutput : Restate.Vm -> Either Restate.TerminalFailure Bytes ->{IO, Exception} ()
Restate.Vm.sysWriteOutput vm result =
