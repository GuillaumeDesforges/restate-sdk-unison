  Restate.Native.withTextIn name (pin -> len ->
    Restate.Native.decodeBytes Restate.Native.decodeRunHandle
      (Restate.Native.withOutBuf 128 (rpin -> rcap ->
        f (Restate.Vm.vmHandle vm) pin len rpin rcap
      ))
  )

Restate.Vm.proposeRunCompletion : Restate.Vm -> Nat -> Either Restate.TerminalFailure Bytes ->{IO, Exception} ()
Restate.Vm.proposeRunCompletion vm nh result =
